#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

#define TRIG 9
#define ECHO 10

char buffer[10];

void setup() {
  pinMode(TRIG, OUTPUT);
  pinMode(ECHO, INPUT);

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();

  // Ozadje
  display.fillRect(0, 0, 128, 64, BLACK);

  // MRE Projekt (modro)
  display.drawRect(80, 0, 48, 12, WHITE);   // okvir
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(83, 2);
  display.print("MRE");
  display.setCursor(105, 2);
  display.print("Projekt");

  display.display();
}

long readDistance() {
  digitalWrite(TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG, LOW);
  long duration = pulseIn(ECHO, HIGH);
  return duration / 58;
}

void loop() {
  long cm = readDistance();

  // Odstrani samo spodnji del ekrana (brez brisanja celotnega zaslona!)
  display.fillRect(0, 20, 128, 44, BLACK);

  // Okvir okoli razdalje
  display.drawRect(10, 25, 108, 30, WHITE);

  // Tekst razdalje
  display.setTextSize(2);
  display.setTextColor(WHITE);
  display.setCursor(20, 32);
  sprintf(buffer, "%ld cm", cm);
  display.print(buffer);

  display.display();
  delay(100);
}
